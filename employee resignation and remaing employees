   class address:
      def __init__ (self,struct,city,zipcode):
          self.struct=struct
          self.city=city
          self.zipcode=zipcode
      def displayaddress(self):
          print(f"address:{self.struct},{self.city},{self.zipcode}")
   def __init__ (self,empid,name,struct,city,zipcode):
      self.empid=empid
      self.name=name
      self.address=employee.address(struct,city,zipcode)
