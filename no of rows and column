for i in range(r):
   e=[]
   for j in range(c):
      n=int(input("enter number"))
      e.append(n)
   l.append(e)
print("row wise")
for i in l:
   print(i)
print("matrix wise")
for j in l:
   for k in j:
      print(k,end='  ')
   print()
